### 3. PROFESSIONAL SERVICE - pyg-professional
### =============================================================================

### Create Professional profile
POST {{professional_host}}/professionals
Content-Type: {{content_type}}
Authorization: Bearer {{auth_token}}

{
    "phone": "+5691234578",
    "address": "Linares, Chile",
    "birthDate": "1998-05-10",
    "profession": "Feline Ethologist",
    "bio": "Expert in feline behavior and environmental enrichment.",
    "experienceYears": 4,
    "petTypes": "CAT",
    "profilePictureUrl": "https://mysite.cl/photo.jpg",
    "instagram": "jess_ethologist",
    "website": "https://mysite.cl",
    "availability": "Mon-Fri 10:00-18:00"
}

> {%
    client.test("Professional profile created", function() {
        client.assert(response.status === 200 || response.status === 201, "Professional creation failed");
    });

    if (response.status === 200 || response.status === 201) {
        const body = JSON.parse(response.body);
        client.global.set("current_professional_id", body.id);
        client.log("🩺 Professional ID saved: " + body.id);
    }
%}

### Get my Professional profile
GET {{professional_host}}/professionals/profile
Authorization: Bearer {{auth_token}}

> {%
    client.test("Professional profile retrieved", function() {
        client.assert(response.status === 200, "Could not fetch pro profile");
    });
%}

### Update my Professional profile
PATCH {{professional_host}}/professionals/profile
Content-Type: {{content_type}}
Authorization: Bearer {{auth_token}}

{
    "bio": "Updated bio: Working with feline behavior and home adaptation.",
    "availability": "Mon-Sat 09:00-18:00"
}

> {%
    client.test("Professional profile patched", function() {
        client.assert(response.status === 200, "Patch update failed");
    });
%}

### List all professionals
GET {{professional_host}}/professionals
Authorization: Bearer {{auth_token}}

> {%
    client.test("Professionals list retrieved", function() {
        client.assert(response.status === 200, "Could not fetch pro list");
    });
%}

### Get professional by ID
GET {{professional_host}}/professionals/{{current_professional_id}}
Authorization: Bearer {{auth_token}}

> {%
    client.test("Professional details by ID retrieved", function() {
        client.assert(response.status === 200, "Could not fetch pro by ID");
    });
%}

###
### 4. ERROR TESTS - Security Check
### =============================================================================

### Try access without token (should give 401)
GET {{owner_host}}/owners/profile

> {%
    client.test("Access denied without token", function() {
        client.assert(response.status === 401, "Security flaw: Access granted without token");
    });
    client.log("🛡️ Security check passed: 401 Unauthorized");
%}

### Try access with bad token (should give 401)
GET {{owner_host}}/owners/profile
Authorization: Bearer bad_token_123

> {%
    client.test("Access denied with invalid token", function() {
        client.assert(response.status === 401, "Security flaw: Access granted with bad token");
    });
    client.log("🛡️ Security check passed: 401 Invalid Token");
%}