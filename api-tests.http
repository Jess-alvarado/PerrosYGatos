### PERROS & GATOS - API TESTS
### Environment: {{dev}} - Select environment in IntelliJ
### =============================================================================

### =============================================================================
### 1. AUTHENTICATION - pyg-auth
### =============================================================================

### Register new user
POST {{auth_host}}/{{api_version}}/auth/register
Content-Type: {{content_type}}

{
  "username": "usernameee{{session_id}}@example.cl",
  "password": "Password123!",
  "firstname": "jasmine",
  "lastname": "cabello",
  "rolename": "ROLE_OWNER"
}

> {%
    const timestamp = new Date().getTime();
    client.global.set("session_id", timestamp);

    client.test("User registered successfully", function() {
        client.assert(response.status === 200 || response.status === 201, "Registration failed");
    });

    if (response.status === 200 || response.status === 201) {
        const body = JSON.parse(response.body);
        const sentData = JSON.parse(request.body);
        const emailUsed = sentData.username;
        client.global.set("last_registered_email", emailUsed);
        client.global.set("auth_token", body.accessToken);
        client.global.set("refresh_token", body.refreshToken);
        client.log("✅ Success - Tokens saved");
    }
%}

### Login (get tokens)
POST {{auth_host}}/{{api_version}}/auth/login
Content-Type: {{content_type}}

{
  "username": "{{last_registered_email}}",
  "password": "Password123!"
}

> {%
    client.test("Login successful", function() {
        client.assert(response.status === 200, "Login failed for user: " + client.global.get("last_registered_email"));
    });

    if (response.status === 200) {
        const body = JSON.parse(response.body);
        client.global.set("auth_token", body.accessToken);
        client.global.set("refresh_token", body.refreshToken);
        client.log("✅ Tokens updated for user: " + body.username);
    }
%}

### Validate current token
POST {{auth_host}}/{{api_version}}/auth/validate
Authorization: Bearer {{auth_token}}

> {%
    client.test("Token is valid", function() {
        client.assert(response.status === 200, "Invalid token");
    });
%}

### Refresh token
POST {{auth_host}}/{{api_version}}/auth/refresh
Content-Type: {{content_type}}

{
  "refreshToken": "{{refresh_token}}"
}

> {%
    client.test("Tokens refreshed successfully", function() {
        client.assert(response.status === 200, "Refresh failed");
    });

    if (response.status === 200) {
        const body = JSON.parse(response.body);
        client.global.set("auth_token", body.accessToken);
        client.global.set("refresh_token", body.refreshToken);
        client.log("🔄 Tokens rotated successfully");
    }
%}

### Logout
POST {{auth_host}}/{{api_version}}/auth/logout
Authorization: Bearer {{auth_token}}

> {%
    client.test("Logout successful", function() {
        client.assert(response.status === 200, "Logout failed");
    });
    client.global.clear("auth_token");
    client.global.clear("refresh_token");
    client.log("👋 Session cleared");
%}

