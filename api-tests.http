### 2. OWNER SERVICE - pyg-owner
### =============================================================================

### Create/Update Owner profile
POST {{owner_host}}/owners
Content-Type: {{content_type}}
Authorization: Bearer {{auth_token}}

{
  "phone": "+1234567890",
  "address": "123 Main St, City, State 12345",
  "birthDate": "1998-09-18"
}

> {%
    client.test("Owner profile created/updated", function() {
        client.assert(response.status === 200 || response.status === 201, "Profile action failed");
    });
    client.log("📦 Response: " + response.body);
%}

### Get my Owner profile
GET {{owner_host}}/owners/profile
Authorization: Bearer {{auth_token}}

> {%
    client.test("Owner profile retrieved", function() {
        client.assert(response.status === 200, "Could not fetch owner profile");
    });
%}

### Create/Update Pets profile
POST {{owner_host}}/pets
Content-Type: {{content_type}}
Authorization: Bearer {{auth_token}}

{
    "name": "Batman",
    "type": "CAT",
    "breed": "Tuxedo",
    "age": 8,
    "sterilized": true,
    "sex": "male",
    "behaviorDescription": "Well behaved but curious."
}

> {%
    client.test("Pet profile created", function() {
        client.assert(response.status === 200 || response.status === 201, "Pet creation failed");
    });

    if (response.status === 200 || response.status === 201) {
        const body = JSON.parse(response.body);
        client.global.set("current_pet_id", body.id);
        client.log("🐾 Pet ID saved: " + body.id);
    }
%}

### Get my pets
GET {{owner_host}}/pets/{{current_pet_id}}
Authorization: Bearer {{auth_token}}

> {%
    client.test("Pet details retrieved", function() {
        client.assert(response.status === 200, "Could not fetch pet details");
    });
%}

